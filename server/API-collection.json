{
  "info": {
    "name": "Pharmacy Patient Medication Profile API",
    "description": "API collection for the Pharmacy Patient Medication Profile Management system. Base URL: https://lyrebird04.ifn666.com/a02/api. Protected endpoints require a Bearer JWT token in the Authorization header.",
    "_postman_id": "pharmacy-api-collection-v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://lyrebird04.ifn666.com/a02/api",
      "type": "string"
    },    
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT token — paste the token value from the Login response here"
    },
    {
      "key": "patientId",
      "value": "",
      "type": "string",
      "description": "MongoDB ObjectId of a patient"
    },
    {
      "key": "medicationId",
      "value": "",
      "type": "string",
      "description": "MongoDB ObjectId of a medication"
    },
    {
      "key": "profileId",
      "value": "",
      "type": "string",
      "description": "MongoDB ObjectId of a medication profile"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string",
      "description": "MongoDB ObjectId of a user (for approve/decline)"
    },
    {
      "key": "baseUrLocal",
      "value": "http://localhost:6001/api",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints. Register and Login are public. Pending, Approve, and Decline require a Pharmacist JWT.",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"jsmith\",\n  \"password\": \"securepassword\",\n  \"userRole\": \"pharmacist\",\n  \"isPharmacist\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Register a new staff account. Account is inactive until approved by a Pharmacist."
          }
        },
        {
          "name": "Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"jsmith\",\n  \"password\": \"securepassword\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login and receive a JWT token. Copy the token value into the collection-level 'token' variable."
          }
        },
        {
          "name": "Get Pending Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/users/pending",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "users", "pending"]
            },
            "description": "List all accounts awaiting approval. Pharmacist only."
          }
        },
        {
          "name": "Approve User",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/users/{{userId}}/approve",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "users", "{{userId}}", "approve"]
            },
            "description": "Approve a pending staff account. Pharmacist only. Set the 'userId' collection variable first."
          }
        },
        {
          "name": "Decline User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/users/{{userId}}/decline",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "users", "{{userId}}", "decline"]
            },
            "description": "Decline and permanently remove a pending account. Pharmacist only. Set the 'userId' collection variable first."
          }
        }
      ]
    },
    {
      "name": "Patients",
      "description": "Patient management. All endpoints require authentication. Write operations require a Pharmacist role.",
      "item": [
        {
          "name": "Get All Patients",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/patients?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["patients"]
            },
            "description": "Get all patients (paginated). Pagination navigation links are returned in the Link response header."
          }
        },
        {
          "name": "Search Patients",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/patients/search?name=smith",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "search"],
              "query": [
                {
                  "key": "name",
                  "value": "smith",
                  "description": "Partial or full patient name (case-insensitive)"
                }
              ]
            },
            "description": "Search patients by name. Case-insensitive partial match."
          }
        },
        {
          "name": "Get Patient by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientId}}",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientId}}"]
            },
            "description": "Get a single patient by their MongoDB ObjectId. Set the 'patientId' collection variable first."
          }
        },
        {
          "name": "Create Patient",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Emily\",\n  \"lastName\": \"Doe\",\n  \"address\": \"123 Main St, Brisbane QLD 4000\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/patients",
              "host": ["{{baseUrl}}"],
              "path": ["patients"]
            },
            "description": "Create a new patient record. Pharmacist only."
          }
        },
        {
          "name": "Update Patient",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"address\": \"456 Queen St, Brisbane QLD 4000\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientId}}",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientId}}"]
            },
            "description": "Update an existing patient. Pharmacist only. Set the 'patientId' collection variable first."
          }
        },
        {
          "name": "Delete Patient",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientId}}",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientId}}"]
            },
            "description": "Delete a patient. Pharmacist only. Set the 'patientId' collection variable first."
          }
        }
      ]
    },
    {
      "name": "Medications",
      "description": "Medication catalogue management. All endpoints require authentication. Write operations require a Pharmacist role.",
      "item": [
        {
          "name": "Get All Medications",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/medications?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["medications"]
            },
            "description": "Get all medications (paginated). Pagination navigation links are returned in the Link response header."
          }
        },
        {
          "name": "Search Medications",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/medications/search?activeIngredient=paracetamol",
              "host": ["{{baseUrl}}"],
              "path": ["medications", "search"],
              "query": [
                {
                  "key": "medicationName",
                  "value": "paracetamol",
                  "description": "Active ingredient to search for (case-insensitive)"
                }
              ]
            },
            "description": "Search medications by active ingredient."
          }
        },
        {
          "name": "Get Medication by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/medications/{{medicationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["medications", "{{medicationId}}"]
            },
            "description": "Get a single medication by its MongoDB ObjectId. Set the 'medicationId' collection variable first."
          }
        },
        {
          "name": "Create Medication",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"brandName\": \"Staphlex\",\n  \"activeIngredient\": \"flucloxacillin\",\n  \"strength\": \"500mg\",\n  \"form\": \"capsule\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/medications",
              "host": ["{{baseUrl}}"],
              "path": ["medications"]
            },
            "description": "Add a new medication to the catalogue. Pharmacist only."
          }
        },
        {
          "name": "Update Medication",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"brandName\": \"Panadol Extra\",\n  \"strength\": \"500mg/65mg\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/medications/{{medicationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["medications", "{{medicationId}}"]
            },
            "description": "Update a medication in the catalogue. Pharmacist only. Set the 'medicationId' collection variable first."
          }
        },
        {
          "name": "Delete Medication",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/medications/{{medicationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["medications", "{{medicationId}}"]
            },
            "description": "Remove a medication from the catalogue. Pharmacist only. Set the 'medicationId' collection variable first."
          }
        }
      ]
    },
    {
      "name": "Medication Profiles",
      "description": "Medication profile management, nested under a Patient. All endpoints require authentication. Write operations require a Pharmacist role. Set 'patientId' before using any request in this folder.",
      "item": [
        {
          "name": "Get All Profiles for Patient",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientId}}/medicationProfiles?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientId}}", "medicationProfiles"]
            },
            "description": "Get all medication profiles for a specific patient (paginated). Pagination navigation links are returned in the Link response header."
          }
        },
        {
          "name": "Get Profile by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientId}}/medicationProfiles/{{profileId}}",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientId}}", "medicationProfiles", "{{profileId}}"]
            },
            "description": "Get a specific medication profile by its ObjectId. Set both 'patientId' and 'profileId' collection variables first."
          }
        },
        {
          "name": "Create Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"medication\": \"{{medicationId}}\",\n  \"dose\": \"500mg\",\n  \"frequency\": \"twice daily\",\n  \"status\": \"active\",\n  \"startDate\": \"2026-04-15\",\n  \"notes\": \"Take with food\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientId}}/medicationProfiles",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientId}}", "medicationProfiles"]
            },
            "description": "Create a new medication profile for a patient. Pharmacist only. Set 'patientId' and 'medicationId' collection variables first."
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dose\": \"1000mg\",\n  \"frequency\": \"once daily\",\n  \"status\": \"ceased\",\n  \"endDate\": \"2026-04-18\",\n  \"notes\": \"Dosage increased by specialist\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientId}}/medicationProfiles/{{profileId}}",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientId}}", "medicationProfiles", "{{profileId}}"]
            },
            "description": "Update a medication profile. Pharmacist only. Set 'patientId' and 'profileId' collection variables first."
          }
        },
        {
          "name": "Delete Profile",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientId}}/medicationProfiles/{{profileId}}",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientId}}", "medicationProfiles", "{{profileId}}"]
            },
            "description": "Delete a medication profile. Pharmacist only. Set 'patientId' and 'profileId' collection variables first."
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Public endpoint. Returns server uptime status."
          }
        }
      ]
    }
  ]
}